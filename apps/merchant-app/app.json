{
  "expo": {
    "name": "NearNow Merchant",
    "slug": "nearnow-merchant",
    "scheme": "nearnow-merchant",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "launcher"
        }
      ]
    ],
    "android": {
      "package": "com.nearnow.merchant"
    },
    "ios": {
      "bundleIdentifier": "com.nearnow.merchant"
    },
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "web": {
      "bundler": "metro"
    },
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "4425f664-7429-4b2e-ab4f-a9fb8da4d156"
      }
    },
    "owner": "plgdinn"
  }
}
